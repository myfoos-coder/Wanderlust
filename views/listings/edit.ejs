<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">    
<h3>Edit your Listing</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
       <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" value="<%= listing.title %>" class="form-control" type="text" required>
        <div class="valid-feedback">
      Looks good!
    </div>
    <div class="invalid-feedback">
      Please provide a title.  </div>
       </div>
       <div class="mb-3">
        <label for="discription" class="form-label">Discription</label>
        <textarea name="listing[description]" class="form-control" type="text" required><%= listing.description %></textarea>
        <div class="invalid-feedback">
      Please provide a valid description.
    </div>
    </div>
        <!-- ...existing code... -->
    <div class="mb-3">
      Original Listing Image:<br>
      <img src="<%= originalImageUrl %>" alt="Listing Image" class="img-thumbnail" style="max-width: 250px;">
    </div>


<div class="mb-3">
  <label for="image" class="form-label">Upload New Image</label>
  <input name="listing[image]" class="form-control" type="file" >
</div>
        <div class="row">
        <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" class="form-control" value="<%= listing.price %>" type="number" required>
        <div class="invalid-feedback">
      Please provide a valid price.
    </div>
    </div>
        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" class="form-control" value="<%= listing.country %>" type="text" required>
        <div class="invalid-feedback">
      Please provide a valid country.
       </div>
       </div>
        <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input id="location" name="listing[location]" class="form-control" value="<%= listing.location %>" type="text" required>
        <div class="invalid-feedback">
      Please provide a valid location.  
        </div>
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="countryCode" class="form-label">Country Code</label>
            <select name="listing[countryCode]" id="countryCode" class="form-select" required>
              <option value="91" <%= listing.countryCode === "91" ? "selected" : "" %>>+91 India</option>
              <option value="44" <%= listing.countryCode === "44" ? "selected" : "" %>>+44 UK</option>
              <option value="1" <%= listing.countryCode === "1" ? "selected" : "" %>>+1 USA</option>
              <option value="61" <%= listing.countryCode === "61" ? "selected" : "" %>>+61 Australia</option>
              <option value="81" <%= listing.countryCode === "81" ? "selected" : "" %>>+81 Japan</option>
              <option value="49" <%= listing.countryCode === "49" ? "selected" : "" %>>+49 Germany</option>
            </select>
          </div>
          <div class="mb-3 col-md-8">
            <label for="contactNumber" class="form-label">Contact Number</label>
            <input name="listing[contactNumber]" id="contactNumber" class="form-control" value="<%= listing.contactNumber %>" type="tel" inputmode="numeric" pattern="[0-9]{6,12}" required>
            <div class="invalid-feedback">
              Please provide a valid contact number.
            </div>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label d-block">Availability</label>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="listing[available]" id="availableYes" value="true" <%= listing.available !== false ? "checked" : "" %>>
            <label class="form-check-label" for="availableYes">Available</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="listing[available]" id="availableNo" value="false" <%= listing.available === false ? "checked" : "" %>>
            <label class="form-check-label" for="availableNo">Unavailable</label>
          </div>
        </div>
        </div>
        <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
    </div>
</div>


