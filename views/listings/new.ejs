<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
    <div class="col-8 offset-2">
        <br><br>
    <h3>Create a New Listing</h3>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" placeholder="Enter a catchy title" type="text" class="form-control" required>
        <div class="valid-feedback">
      Looks good!
    </div>
    <div class="invalid-feedback">
      Please provide a title.  </div>
       </div>
       <div class="mb-3">
       <label for="discription" class="form-label">Discription</label>
        <textarea name="listing[description]" placeholder="enter description" type="text" class="form-control" required></textarea>
      
    <div class="invalid-feedback">
      Please provide a valid description.
    </div>
    </div>
        <div class="mb-3">
        <label for="image" class="form-label">Upload Image</label>
        <input name="listing[image]" type="file" class="form-control" required>
        </div>
        <div class="row">
        <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" placeholder="1200"  class="form-control" required>
        
    <div class="invalid-feedback">
      Please provide a valid price.
    </div>
        </div>
        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
        <div class="invalid-feedback">
      Please provide a valid country.
       </div>
       </div>
        <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input name="listing[location]" placeholder="Banglore, Karnataka" type="text" class="form-control" required>
        <div class="invalid-feedback">
      Please provide a valid location.  
        </div>
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="countryCode" class="form-label">Country Code</label>
            <select name="listing[countryCode]" id="countryCode" class="form-select" required>
              <option value="91" selected>+91 India</option>
              <option value="44">+44 UK</option>
              <option value="1">+1 USA</option>
              <option value="61">+61 Australia</option>
              <option value="81">+81 Japan</option>
              <option value="49">+49 Germany</option>
            </select>
          </div>
          <div class="mb-3 col-md-8">
            <label for="contactNumber" class="form-label">Contact Number</label>
            <input name="listing[contactNumber]" id="contactNumber" placeholder="9876543210" type="tel" inputmode="numeric" pattern="[0-9]{6,12}" class="form-control" required>
            <div class="invalid-feedback">
              Please provide a valid contact number.
            </div>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label d-block">Availability</label>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="listing[available]" id="availableYes" value="true" checked>
            <label class="form-check-label" for="availableYes">Available</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="listing[available]" id="availableNo" value="false">
            <label class="form-check-label" for="availableNo">Unavailable</label>
          </div>
        </div>
        <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
    <br><br>
    </div>
    </div>

